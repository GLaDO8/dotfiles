# Ghostty Configuration

# FONTS
font-family = TX-02
font-size = 15
font-thicken=true
font-thicken-strength=50
adjust-cell-height=8

# CURSOR
cursor-style = block
cursor-style-blink = true
mouse-hide-while-typing = true

# THEME (Neon Blue Split Contrast)
background = #0a0a0a
foreground = #00ff00
cursor-color = #ff00ff
unfocused-split-opacity = 0.7
# unfocused-split-fill = #001a4d
split-divider-color = #ff7348
selection-background = #0047ff
selection-foreground = #ffffff
palette = 0=#000000
palette = 1=#ff0055
palette = 2=#00ff66
palette = 3=#ffee00
palette = 4=#0099ff
palette = 5=#ff00ff
palette = 6=#00ffee
palette = 7=#ffffff
palette = 8=#444444
palette = 9=#ff3366
palette = 10=#33ff99
palette = 11=#ffff66
palette = 12=#33bbff
palette = 13=#ff33ff
palette = 14=#66ffff
palette = 15=#ffffff

# WINDOW
window-padding-x = 8
window-padding-y = 8
macos-titlebar-style = hidden
window-colorspace = display-p3
focus-follows-mouse = true

# macOS
macos-option-as-alt = true
macos-titlebar-style = native
keybind = cmd+t=new_tab
keybind = global:cmd+backquote=toggle_quick_terminal
quick-terminal-size = 30%,50%
link-previews = true
clipboard-trim-trailing-spaces = true
copy-on-select = true

# SHELL INTEGRATION
shell-integration-features = no-cursor

# Shaders
# custom-shader = ~/.config/ghostty/shaders/bettercrt.glsl
# custom-shader = ~/.config/ghostty/shaders/tft.glsl
# custom-shader = ~/.config/ghostty/shaders/retro-terminal.glsl
custom-shader = ~/.config/ghostty/shaders/glow-rgbsplit-twitchy.glsl
# custom-shader = ~/.config/ghostty/shaders/bloom.glsl
custom-shader-animation = true

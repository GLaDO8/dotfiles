# Ghostty Configuration

# FONTS
font-family = TX-02
font-size = 15
font-thicken=true
font-thicken-strength=50
adjust-cell-height=8

# CURSOR
cursor-style = block
cursor-style-blink = true
mouse-hide-while-typing = true

# NERV/EVA-01 inspired palette
background = #0a0a12
foreground = #c8e0c8

# Greens (EVA-01 / MAGI displays)
palette = 0=#0a0a12
palette = 1=#ff3333
palette = 2=#44cc44
palette = 3=#ff9900
palette = 4=#6633cc
palette = 5=#cc33ff
palette = 6=#33cccc
palette = 7=#a0b8a0

# Bright variants
palette = 8=#333344
palette = 9=#ff6666
palette = 10=#66ff66
palette = 11=#ffcc33
palette = 12=#9966ff
palette = 13=#ff66ff
palette = 14=#66ffcc
palette = 15=#d0e8d0

cursor-color = #ff6600
cursor-text = #000000
selection-background = #334433
selection-foreground = #66ff66

# WINDOW
window-padding-x = 8
window-padding-y = 8
macos-titlebar-style = native
window-title-font-family = TX-02
window-colorspace = display-p3
focus-follows-mouse = true

# macOS
macos-option-as-alt = true
keybind = cmd+t=new_tab
keybind = global:cmd+backquote=toggle_quick_terminal
keybind = alt+left=esc:[1;3D
keybind = alt+right=esc:[1;3C
keybind = alt+up=esc:[1;3A
keybind = alt+down=esc:[1;3B
quick-terminal-size = 30%,50%
link-previews = true
clipboard-trim-trailing-spaces = true
copy-on-select = false

# SHELL INTEGRATION
shell-integration-features = no-cursor
# command = /opt/homebrew/bin/zellij

# Shaders
# custom-shader = ~/.config/ghostty/shaders/bettercrt.glsl
# custom-shader = ~/.config/ghostty/shaders/tft.glsl
# custom-shader = ~/.config/ghostty/shaders/retro-terminal.glsl
# custom-shader = ~/.config/ghostty/shaders/glow-rgbsplit-twitchy.glsl
# custom-shader = ~/.config/ghostty/shaders/bloom.glsl
custom-shader-animation = true

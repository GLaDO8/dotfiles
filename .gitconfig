[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
[user]
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEih28/tn26DlL1gJjfz0Xlj8VxjzYMvZzdPr6o43QNm
	name = GLaDO8
	email = gshreyas@icloud.com
[core]
	pager = delta
[init]
	defaultBranch = main
[url "git@github.com:"]
	insteadOf = https://github.com/
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = false
[merge]
	conflictstyle = diff3
[diff]
	colorMoved = default
